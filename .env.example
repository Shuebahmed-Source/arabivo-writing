# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: proxy Clerk Frontend API on YOUR domain (fixes CORS to clerk.<your-domain>).
# Must match Clerk Dashboard → Domains → Frontend API proxy URL. Include trailing slash.
# Example: NEXT_PUBLIC_CLERK_PROXY_URL=https://write.arabivo.net/__clerk/
NEXT_PUBLIC_CLERK_PROXY_URL=

# Path-based hosted sign-in/up (must match app routes; avoids broken redirects if unset)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# If you open the app via LAN (e.g. http://172.20.x.x:3000), add that exact origin in
# Clerk Dashboard → Configure → Paths → Allowed origins / redirect URLs.

# Public site URL (https://…). Used for Stripe return URLs and other absolute links on Vercel.
# See Projectdocs/clerk-production.md and Projectdocs/stripe.md.
NEXT_PUBLIC_APP_URL=

# PostHog — https://posthog.com (optional; omit key to disable client analytics)
# Use a different project key on Vercel Preview vs Production if desired.
NEXT_PUBLIC_POSTHOG_KEY=
# e.g. https://us.i.posthog.com or https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=

# Supabase — https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: Project Settings → API → service_role (never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — https://dashboard.stripe.com
# Webhook endpoint: https://<your-domain>/api/webhooks/stripe (events below)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# One-time lifetime price (£54) and recurring monthly price (£7.99) — both price_... ids
STRIPE_LIFETIME_PRICE_ID=
STRIPE_MONTHLY_PRICE_ID=

# Optional: comma-separated emails with full access without Stripe (trimmed, case-insensitive match to Clerk emails).
# FREE_ACCESS_EMAILS=you@example.com,teammate@example.com
FREE_ACCESS_EMAILS=
