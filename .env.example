# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Path-based hosted sign-in/up (must match app routes; avoids broken redirects if unset)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/lessons
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/lessons

# If you open the app via LAN (e.g. http://172.20.x.x:3000), add that exact origin in
# Clerk Dashboard → Configure → Paths → Allowed origins / redirect URLs.

# Public site URL (https://…). Used for Stripe return URLs and other absolute links on Vercel.
# See Projectdocs/clerk-production.md and Projectdocs/stripe.md.
NEXT_PUBLIC_APP_URL=

# Supabase — https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: Project Settings → API → service_role (never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — https://dashboard.stripe.com (Products → create recurring Price; copy Price ID)
# Webhook endpoint: https://<your-domain>/api/webhooks/stripe (events below)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
